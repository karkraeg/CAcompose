# TLS certificates — never commit private keys
nginx/certs/*.crt
nginx/certs/*.key
nginx/certs/*.pem

# Local media uploads
media/*
!media/.gitkeep

# Batch media import staging
import/*
!import/.gitkeep

# Runtime data written by containers
data/providence/log/*
data/providence/tmp/*
data/pawtucket2/log/*
data/pawtucket2/tmp/*
!data/**/.gitkeep

# Environment file with real credentials
# (keep .env.example instead if you have one)
.env

.claude/
# Database
MYSQL_ROOT_PASSWORD=changeme_root
CA_DB_HOST=db
CA_DB_PORT=3306
CA_DB_USER=ca_user
CA_DB_PASSWORD=changeme_ca
CA_DB_DATABASE=ca_database

# Application
CA_APP_DISPLAY_NAME=My CollectiveAccess
CA_ADMIN_EMAIL=admin@example.com
CA_DEFAULT_LOCALE=en_US
TZ=UTC

# Redis
CA_REDIS_HOST=redis
CA_REDIS_PORT=6379
CA_CACHE_BACKEND=redis

# Providence Redis DB index (0) / Pawtucket2 Redis DB index (1)
CA_PROVIDENCE_REDIS_DB=0
CA_PAWTUCKET2_REDIS_DB=1

# Theme for Pawtucket2 (folder name under pawtucket2/themes/)
CA_PAWTUCKET2_THEME=default

# Git branch/tag to build from
CA_PROVIDENCE_VERSION=master
CA_PAWTUCKET2_VERSION=master

# Media directory — shared between providence and pawtucket2 containers.
# Must be an absolute path or a path relative to this file.
# Create it before first run: mkdir -p ./media
MEDIA_PATH=./media
